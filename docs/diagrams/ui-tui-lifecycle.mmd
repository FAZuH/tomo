sequenceDiagram
    autonumber
    participant U as User
    participant V as TuiView
    participant TU as TimerUpdate
    participant SU as SettingsUpdate
    participant TR as TuiRenderer

    rect rgb(180, 200, 220)
        note right of V: INITIALIZATION
        V->>V: enable_raw_mode()
        V->>TR: TuiRenderer::new()
        activate TR
        TR-->>V: renderer
        deactivate TR
    end

    rect rgb(180, 220, 190)
        note right of V: MAIN LOOP (TICK)
        loop Until Quit
            V->>V: pomodoro.tick()
            
            opt Needs Redraw
                V->>TR: flush(frame, router, pomodoro, config)
                activate TR
                TR-->>V: frame drawn
                deactivate TR
                V->>V: terminal.draw()
            end

            V->>V: poll input
            opt Has Input
                alt Page::Timer
                    V->>TU: update(TimerMsg, pomodoro)
                    activate TU
                    TU-->>V: new_pomodoro
                    deactivate TU
                else Page::Settings
                    V->>SU: update(SettingsMsg, config)
                    activate SU
                    SU-->>V: new_config
                    deactivate SU
                else Navigation
                    V->>V: router.navigate(GoTo or Quit)
                end
            end
        end
    end
