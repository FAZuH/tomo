sequenceDiagram
    autonumber
    participant U as User
    participant R as TuiRunner
    participant TH as TickHandler
    participant P as Pomodoro
    participant C as Config
    participant V as TuiView
    participant T as ToastHandler
    participant S as SoundService

    rect rgb(180, 200, 220)
        note right of R: INITIALIZATION
        R->>R: Router::new(Page::Timer)
        R->>V: TuiView::new()
        activate V
        V-->>R: view
        deactivate V
        R->>R: snapshot_settings()
    end

    rect rgb(180, 220, 190)
        note right of R: MAIN LOOP
        loop Until Quit
            R->>TH: new_tick()
            TH-->>R: tick_elapsed?

            opt Has Input
                alt Page::Timer
                    R->>R: handle_timer(event)
                    opt prompt_transition
                        R->>R: handle_timer_transition(event)
                        alt Enter / 'y'
                            R->>R: transition()
                            R->>R: update_timer(SetPromptNextSession(false))
                        else Esc / 'n'
                            R->>R: quit()
                        end
                    end
                    R->>P: update(PomodoroMsg)
                    activate P
                    P-->>R: PomodoroCmd
                    deactivate P
                    R->>R: handle_pomodoro_cmd(cmd)
                else Page::Settings
                    R->>R: handle_settings(event)
                    alt Is Editing
                        R->>R: handle_settings_edit(event)
                        alt Prompt Done
                            R->>R: apply_settings_edit()
                            R->>R: update_settings(CancelEditing)
                            R->>C: update(ConfigMsg)
                            activate C
                            C-->>R: ConfigCmd
                            deactivate C
                            R->>R: update_settings(SetUnsavedChanges(bool))
                        else Prompt Aborted
                            R->>R: update_settings(CancelEditing)
                        end
                    else Is Navigating
                        R->>R: update_settings(SettingsMsg)
                    end
                end
                R->>R: redraw = true
            end

            opt Redraw
                R->>R: tick()
                R->>P: update(Tick { auto_next })
                activate P
                P-->>R: PomodoroCmd
                deactivate P
                R->>R: handle_pomodoro_cmd(cmd)

                opt PomodoroCmd::PromptNextSession
                    R->>R: on_session_end()
                    R->>R: update_timer(SetPromptNextSession(true))
                end

                opt PomodoroCmd::NextSession
                    R->>R: on_session_end()
                    R->>S: play_sound(next_mode)
                    R->>R: send_notification(next_mode)
                    R->>R: run_hooks(hooks, curr_mode)
                    R->>R: transition()
                end

                R->>V: render_stateful_ref(frame, canvas, state)
                activate V
                V-->>R: frame drawn
                deactivate V
                R->>T: tick()
                R->>T: render(area, buffer)
                R->>R: terminal.draw()
            end

            R->>R: sleep(10ms)
        end
    end
