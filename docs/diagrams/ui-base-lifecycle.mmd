sequenceDiagram
    autonumber
    participant R as Runner
    participant TH as TickHandler
    participant P as Pomodoro
    participant C as Config
    participant V as View

    rect rgb(180, 200, 220)
        note right of R: INITIALIZATION
        R->>R: Router::new(Page::Timer)
        activate R
        R-->>R: router
        deactivate R
    end

    rect rgb(180, 220, 190)
        note right of R: EVENT LOOP
        loop Until Quit
            R->>TH: new_tick()
            TH-->>R: tick_elapsed?

            opt Has Input
                alt Timer Input
                    R->>R: Map input to PomodoroMsg
                    R->>P: update(msg)
                    activate P
                    P-->>R: PomodoroCmd
                    deactivate P
                    R->>R: handle_pomodoro_cmd(cmd)
                else Settings Input
                    R->>R: Map input to ConfigMsg
                    R->>C: update(msg)
                    activate C
                    C-->>R: ConfigCmd
                    deactivate C
                else Navigation Input
                    R->>R: Router::navigate(Navigation)
                end
                R->>R: redraw = true
            end

            opt Redraw
                R->>V: render_stateful_ref(frame, context, state)
            end
        end
    end
